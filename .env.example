DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SECRET_KEY=minha-chave-secreta-de-producao-muito-segura
JWT_SECRET_KEY=outra-chave-secreta-para-jwt
OCR_PROVIDER=easyocr
OCR_COMPARE_PRIMARY=paddle
# Rede local/offline do DJI Tello
TELLO_HOST=192.168.10.1
TELLO_COMMAND_PORT=8889
TELLO_LOCAL_PORT=9000
TELLO_STATE_PORT=8890
# Opcional: fixe o IP local do Wi-Fi conectado ao Tello, ex. 192.168.10.2
TELLO_LOCAL_IP=
TELLO_VIDEO_HOST=0.0.0.0
TELLO_VIDEO_PORT=11111
# Opcional: sobrescreve TELLO_VIDEO_HOST/TELLO_VIDEO_PORT
TELLO_VIDEO_URL=
TELLO_WEBRTC_HOST=0.0.0.0
TELLO_WEBRTC_PORT=8765
# Opcional: magnitude dos comandos de voo enviados pelos botoes do dashboard
# up/down/frente/tras em cm (20-500); esquerda/direita = rotacao cw/ccw em graus (1-360)
TELLO_MOVE_DISTANCE_CM=30
TELLO_ROTATE_DEGREES=30
# Opcional: tempo (s) que o servidor aguarda a resposta do Tello a um comando
# de controle. Cobre a duracao da manobra (forward/back/takeoff so respondem ok
# apos concluir). Veja docs/sprint-5/controle-voo-dashboard.md (secao 12).
TELLO_COMMAND_TIMEOUT=12
# Opcional: controle continuo (rc a b c d) via WebSocket /control.
# TELLO_RC_SPEED_MAX = teto de magnitude por eixo (1-100).
# TELLO_RC_WATCHDOG_MS = se o drone estiver em movimento e nao chegar rc nesse
# tempo, o servidor faz pairar (rc 0 0 0 0) — protege contra runaway.
TELLO_RC_SPEED_MAX=100
TELLO_RC_WATCHDOG_MS=400

# Frontend: servidor local que converte o stream UDP do Tello para WebRTC
VITE_DRONE_WEBRTC_URL=http://localhost:8765
VITE_DRONE_TELEMETRY_WS_URL=ws://localhost:8765/telemetry
VITE_DRONE_CONTROL_WS_URL=ws://localhost:8765/control

# Chamadas de API/Internet
PIER_API_URL=http://localhost:5000
# Opcional: fixe o IP de origem da interface com Internet, ex. dongle Wi-Fi,
# Ethernet/cabo ou iPhone USB 172.20.10.4
PIER_API_SOURCE_IP=
API_SOURCE_IP=
DATABASE_CONNECT_TIMEOUT=10
