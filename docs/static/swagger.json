      "post": {
        "description": "Rota usada pelo firmware do drone ou pelo sistema de processamento de imagem.<br/>",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "id_drone": {
                  "type": "string"
                },
                "imagem_url": {
                  "example": "https://storage.exemplo.com/scans/img123.jpg",
                  "type": "string"
                },
                "latitude": {
                  "example": -23.5505,
                  "type": "number"
                },
                "longitude": {
                  "example": -46.6333,
                  "type": "number"
                },
                "match": {
                  "example": true,
                  "type": "boolean"
                },
                "placa": {
                  "example": "ABC1D23",
                  "type": "string"
                }
              },
              "required": [
                "id_drone",
                "placa",
                "match"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Scan registrado com sucesso"
          },
          "400": {
            "description": "Dados inv\u00e1lidos"
          }
        },
        "security": [
          {
            "Bearer": []
