          "400": {
            "description": "Dados inv\u00e1lidos"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Adiciona um novo drone a uma opera\u00e7\u00e3o",
        "tags": [
          "Drones"
